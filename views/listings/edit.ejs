<% layout("/layout/boilerplate")%>
<div class="row">
<div class="col-8 offset-2">
<body>
    <h2>Edit list</h2>
    <h4><%=list._id%></h4>
    <form method="post" action="/listing/<%=list._id%>?_method=PUT">
        <div class="mb-3">    
            <label for="title">Title</label>  
              <input name="list[title]" value="<%=list.title%>" type="text" class="form-control">
        </div>
        <div class="mb-3">
            <label for="description">Description</label>
        <textarea name="list[description]" class="form-control" type="text" ><%=list.description%></textarea>
        </div>
        <div class="mb-3">
            <label for="price">Price</label>
         <input type="number" name="list[price]" class="form-control" value="<%=list.price%>">

        </div>
        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="location">Location</label>
            <input type="text" name="list[location]" class="form-control"   vlaue="<%=list.location%>">

        </div>
        <div class="mb-3 col-md-8">
         <label for="country">Country</label>
          <input type="text" name="list[country]" value="<%=list.country%>" class="form-control">

        </div>
        </div>
        <button class="btn btn-dark add-btn mt-3">Edit</button>

    </form>
    
</body>
</div>
</div>
