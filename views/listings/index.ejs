<% layout("/layout/boilerplate")%>
<body>
    <h1>Listings</h1>
    <!-- <form method="get" action="/listing/new">
      <button>Create new list</button>
    </form> -->
    <div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-1">
     <% for(let list of allListings){%>
      <a href="/listing/<%=list._id%>" class="listing-link">
    <div class="card col" style="width: 20rem;">
  <img src="<%=list.image.url%>" class="card-img-top" alt="listing image" style="height: 20rem;">
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text"><b><%=list.title%></b><br>
     <%=list.price%> /night
    </p>
  </div>
  </div>
  </a>
  <% } %>
    </div>
 </body>
     

